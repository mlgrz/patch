generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model issues {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id      String           @db.Uuid
  title           String
  type            String
  description     String?
  status          String
  hide_in_roadmap Boolean          @default(false)
  resolved_at     DateTime?        @db.Timestamptz(6)
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  projects        projects         @relation(fields: [project_id], references: [id], onDelete: Cascade)
  release_issues  release_issues[]
  report_issues   report_issues[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model projects {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_id    String     @db.Uuid
  name        String
  description String?
  public_slug String     @unique
  public_url  String     @unique
  app_type    String[]
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  issues      issues[]
  releases    releases[]
  reports     reports[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model release_issues {
  release_id String   @db.Uuid
  issue_id   String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  issues     issues   @relation(fields: [issue_id], references: [id], onDelete: Cascade)
  releases   releases @relation(fields: [release_id], references: [id], onDelete: Cascade)

  @@id([release_id, issue_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model releases {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id     String           @db.Uuid
  version        String
  title          String
  notes          String?
  status         String
  released_at    DateTime         @db.Timestamptz(6)
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  release_issues release_issues[]
  projects       projects         @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model report_attachments {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  report_id  String   @db.Uuid
  file_url   String
  file_type  String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  reports    reports  @relation(fields: [report_id], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model report_issues {
  report_id  String   @db.Uuid
  issue_id   String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  issues     issues   @relation(fields: [issue_id], references: [id], onDelete: Cascade)
  reports    reports  @relation(fields: [report_id], references: [id], onDelete: Cascade)

  @@id([report_id, issue_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model reporters {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email       String?
  fingerprint String    @unique
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  reports     reports[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model reports {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id         String               @db.Uuid
  reporter_id        String               @db.Uuid
  device_os          String
  device_model       String
  type               String
  title              String
  description        String?
  severity           Int                  @db.SmallInt
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  report_attachments report_attachments[]
  report_issues      report_issues[]
  projects           projects             @relation(fields: [project_id], references: [id], onDelete: Cascade)
  reporters          reporters            @relation(fields: [reporter_id], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
}
